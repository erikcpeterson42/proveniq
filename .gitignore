# Dependencies (downloaded code libraries — huge, and easy to re-download)
/node_modules
/.pnp
.pnp.js

# Testing
/coverage

# Next.js build output (auto-generated when the app runs)
/.next/
/out/
/build
/dist

# Secrets — NEVER commit these (API keys, passwords, tokens)
.env
.env*.local
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Editor / OS junk files
.DS_Store
Thumbs.db
*.pem
.vscode/
.idea/

# Vercel deployment cache
/.vercel

# TypeScript cache
*.tsbuildinfo
next-env.d.ts

# Claude Code local settings (personal to your machine)
/.claude
