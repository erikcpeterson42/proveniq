# ---------------------------------------------------------------------------
# ProvenIQ environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit
# `.env.local` — it holds secrets. (.gitignore already blocks it.)
# ---------------------------------------------------------------------------

# --- Supabase ---
# Project URL and keys from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret. Bypasses Row Level Security — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Follow Up Boss (CRM) ---
# API key from your FUB account. Used as the HTTP Basic username.
FUB_API_KEY=
# Identifies your integration to FUB (recommended headers).
FUB_X_SYSTEM=
FUB_X_SYSTEM_KEY=

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=

# --- Resend (email digest + valuation reports) ---
RESEND_API_KEY=

# --- Deal Radar / valuations ---
# RentCast API key from app.rentcast.io (free "Developer" plan = 50 calls/mo).
# Leave blank to disable the valuation pipeline entirely.
RENTCAST_API_KEY=
# Hard monthly cap on RentCast calls (default 45; raise after upgrading plans).
RENTCAST_MONTHLY_BUDGET=
# Max leads valued per nightly run (default 10).
VALUATION_MAX_PER_RUN=
# Sender for client-facing valuation emails (domain must be verified in Resend).
VALUATION_FROM="Proven Realty <valuation@provenrealtynd.com>"
# Optional reply-to so client replies land in a monitored inbox.
VALUATION_REPLY_TO=
# Contact info shown on the report page / PDF call-to-action.
VALUATION_CONTACT_EMAIL=valuation@provenrealtynd.com
PROVEN_PHONE=

# --- Cron / app ---
# Shared secret the nightly Vercel Cron job sends to prove it's authorized.
CRON_SECRET=
# Public base URL of the deployed app, e.g. https://proveniq.vercel.app
APP_URL=
