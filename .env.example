# ---------------------------------------------------------------------------
# ProvenIQ environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit
# `.env.local` — it holds secrets. (.gitignore already blocks it.)
# ---------------------------------------------------------------------------

# --- Supabase ---
# Project URL and keys from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only secret. Bypasses Row Level Security — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Follow Up Boss (CRM) ---
# API key from your FUB account. Used as the HTTP Basic username.
FUB_API_KEY=
# Identifies your integration to FUB (recommended headers).
FUB_X_SYSTEM=
FUB_X_SYSTEM_KEY=

# --- Anthropic (Claude AI) ---
ANTHROPIC_API_KEY=

# --- Resend (email digest) ---
RESEND_API_KEY=

# --- Cron / app ---
# Shared secret the nightly Vercel Cron job sends to prove it's authorized.
CRON_SECRET=
# Public base URL of the deployed app, e.g. https://proveniq.vercel.app
APP_URL=
